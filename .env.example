# Environment Configuration Template
# Copy this file to .env.local and fill in actual values

# ===================================
# Environment
# ===================================
NODE_ENV=development
LOG_LEVEL=debug

# ===================================
# Database Configuration
# ===================================

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=suberfood_dev
DATABASE_USER=suberfood
DATABASE_PASSWORD=dev_password_change_in_prod
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=suberfood_dev
MONGODB_USER=suberfood
MONGODB_PASSWORD=dev_password_change_in_prod
MONGODB_URL=mongodb://${MONGODB_USER}:${MONGODB_PASSWORD}@${MONGODB_HOST}:${MONGODB_PORT}/${MONGODB_DATABASE}?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ===================================
# Kafka Configuration
# ===================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=suberfood-api
KAFKA_GROUP_ID=suberfood-consumers

# ===================================
# Authentication & Security
# ===================================
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=your-refresh-secret-key
REFRESH_TOKEN_EXPIRES_IN=7d

# Password hashing
BCRYPT_ROUNDS=12

# ===================================
# AWS Configuration (Production)
# ===================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=suberfood-assets
S3_BUCKET_REGION=us-east-1

# ===================================
# MinIO Configuration (Local Dev)
# ===================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=suberfood
MINIO_SECRET_KEY=dev_password_change_in_prod
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=suberfood-dev

# ===================================
# Payment Gateways
# ===================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ===================================
# Communication Services
# ===================================

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@suberfood.com
SENDGRID_FROM_NAME=SuberFood

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ===================================
# External APIs
# ===================================

# Google Maps
GOOGLE_MAPS_API_KEY=

# Weather API (for farm management)
WEATHER_API_KEY=

# ===================================
# Application URLs
# ===================================
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# ===================================
# Monitoring & Logging
# ===================================
SENTRY_DSN=
DATADOG_API_KEY=

# ===================================
# Feature Flags
# ===================================
FEATURE_MULTI_LANGUAGE=true
FEATURE_BLOCKCHAIN_TRACE=false
FEATURE_AI_RECOMMENDATIONS=false
