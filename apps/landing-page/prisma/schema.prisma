// SuberFood Monolithic Database Schema
// Comprehensive schema covering IAM, Distribution, Restaurants, Processing, Farming

generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "debian-openssl-3.0.x", "darwin"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// IDENTITY & ACCESS MANAGEMENT (IAM)
// ========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN

  // Distribution Roles
  DISTRIBUTION_MANAGER
  RESTAURANT_MANAGER
  RESTAURANT_STAFF
  RETAIL_MANAGER
  PARTNER_MANAGER

  // Processing Roles
  PROCESSING_MANAGER
  QUALITY_CONTROL

  // Farming Roles
  FARM_MANAGER
  FARM_WORKER

  // Customer Roles
  CUSTOMER
  B2B_PARTNER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String? // Made optional for OAuth users
  firstName     String? // Made optional for OAuth
  lastName      String? // Made optional for OAuth
  name          String? // Full name for OAuth
  phone         String?
  role          UserRole   @default(CUSTOMER)
  status        UserStatus @default(ACTIVE) // Changed default to ACTIVE for easier onboarding
  emailVerified DateTime?
  image         String?

  // Phase 1: Customer preferences
  favoriteMenuItems   String[] // Menu item IDs
  dietaryRestrictions String[] // vegetarian, vegan, keto, etc.
  allergies           String[] // gluten, dairy, nuts, shellfish, etc.
  birthdate           DateTime?
  communicationPrefs  Json? // Email, SMS preferences

  // Phase 2: Enhanced tracking
  lastLoginAt         DateTime?
  loginCount          Int       @default(0)
  preferredRestaurant String? // Restaurant ID
  lifetimeValue       Float     @default(0) // Total spending
  pointsBalance       Int       @default(0) // Loyalty points

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions     Session[]
  accounts     Account[]
  orders       Order[]
  reservations Reservation[]
  addresses    Address[]
  cart         CartItem[]
  reviews      Review[]
  orderHistory UserOrderHistory[]
  staff        Staff? // One-to-one: User can be a staff member

  @@map("users")
}

// Account model for OAuth providers
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

// Verification tokens for email verification
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// User order history for personalization
model UserOrderHistory {
  id         String   @id @default(cuid())
  userId     String
  menuItemId String? // If restaurant order
  productId  String? // If retail order
  orderId    String
  quantity   Int      @default(1)
  orderedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([menuItemId])
  @@map("user_order_history")
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  type       String // BILLING, SHIPPING, BOTH
  street     String
  city       String
  state      String
  postalCode String
  country    String  @default("USA")
  isDefault  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("addresses")
}

// ========================================
// DISTRIBUTION - RESTAURANTS
// ========================================

enum RestaurantType {
  CLASSICAL_FINE_DINING
  CAFETERIA
  QUICK_SERVICE
}

enum RestaurantStatus {
  OPEN
  CLOSED
  TEMPORARILY_CLOSED
}

model Restaurant {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  type        RestaurantType
  description String?
  address     String
  city        String
  state       String
  postalCode  String
  phone       String
  email       String
  status      RestaurantStatus @default(CLOSED)

  // Operating Hours
  openingTime   String? // e.g., "11:00"
  closingTime   String? // e.g., "22:00"
  operatingDays String? // JSON array of days

  capacity Int   @default(0)
  rating   Float @default(0)

  // Phase 1: Location details
  latitude              Float?
  longitude             Float?
  images                String[] // Array of image URLs
  amenities             String[] // parking, wifi, outdoor seating, etc.
  parkingInfo           String?
  accessibilityFeatures String[] // wheelchair, braille menu, etc.
  privateRooms          Boolean  @default(false)
  outdoorSeating        Boolean  @default(false)
  currentWaitTime       Int? // in minutes

  // Phase 1: About/Story
  story              String? // Restaurant history
  chefBios           Json? // Array of chef profiles
  awards             String[] // Awards and recognition
  sustainabilityInfo String? // Sustainability practices
  pressMedia         Json? // Press coverage links

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-branch support
  parentRestaurantId String? // For multi-branch chains
  isMainBranch       Boolean @default(false)
  branchCode         String? @unique // e.g., "NYC-001", "LA-001"

  // Relations
  menuCategories MenuCategory[]
  reservations   Reservation[]
  tables         Table[]
  orders         Order[]

  // Multi-branch relations
  parentRestaurant Restaurant?  @relation("BranchHierarchy", fields: [parentRestaurantId], references: [id])
  branches         Restaurant[] @relation("BranchHierarchy")

  // Location-specific resources
  staff     Staff[]
  inventory InventoryItem[]
  equipment Equipment[]

  @@map("restaurants")
}

model Table {
  id           String  @id @default(cuid())
  restaurantId String
  tableNumber  String
  capacity     Int
  isAvailable  Boolean @default(true)

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, tableNumber])
  @@map("tables")
}

model MenuCategory {
  id           String  @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("menu_categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  description String?
  price       Float
  salePrice   Float? // For promotional pricing
  image       String?
  images      String[] // Multiple images for gallery
  isAvailable Boolean  @default(true)

  // Phase 1: Dietary information
  isVegetarian Boolean @default(false)
  isVegan      Boolean @default(false)
  isGlutenFree Boolean @default(false)
  isKeto       Boolean @default(false)
  isHalal      Boolean @default(false)
  isKosher     Boolean @default(false)

  // Phase 1: Enhanced details
  calories        Int?
  nutritionInfo   Json? // Nutritional information: protein, carbs, fat, fiber, sodium, sugar
  preparationTime Int? // in minutes
  spiceLevel      Int? // 0-5 scale
  allergens       String[] // gluten, dairy, nuts, shellfish, etc.
  ingredients     String? // Comma-separated or JSON

  // Phase 1: Marketing
  winePairing       String? // Suggested wine/drink pairing
  isChefRecommended Boolean @default(false)
  isSeasonal        Boolean @default(false)
  isPopular         Boolean @default(false)

  // Phase 1: Customer ratings
  averageRating Decimal? @default(0)
  reviewCount   Int      @default(0)

  // Phase 1: Customization options
  customizationOptions Json? // JSON object for modifiers

  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  recipe     Recipe? // One-to-one relationship with Recipe

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("menu_items")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Reservation {
  id           String  @id @default(cuid())
  restaurantId String
  userId       String
  tableId      String?

  reservationDate DateTime
  reservationTime String // e.g., "19:00"
  partySize       Int
  status          ReservationStatus @default(PENDING)

  specialRequests String?
  notes           String?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  table      Table?     @relation(fields: [tableId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reservations")
}

// ========================================
// DISTRIBUTION - E-COMMERCE / RETAIL
// ========================================

enum ProductCategory {
  FRESH_PRODUCE
  DAIRY
  MEAT
  SEAFOOD
  POULTRY
  PROCESSED_FOODS
  BEVERAGES
  BAKERY
  FROZEN
  PANTRY
}

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
  COMING_SOON
}

model Product {
  id          String          @id @default(cuid())
  sku         String          @unique
  name        String
  slug        String          @unique
  description String?
  category    ProductCategory
  status      ProductStatus   @default(ACTIVE)

  price     Float
  salePrice Float?
  cost      Float? // For margin calculation

  // Inventory
  stockQuantity     Int @default(0)
  lowStockThreshold Int @default(10)

  // Product Details
  unit       String // kg, lbs, piece, etc.
  weight     Float?
  dimensions String? // JSON: {length, width, height}

  // Images
  images    String[] // Array of image URLs
  thumbnail String?

  // Traceability
  farmSource         String?
  processingLocation String?
  harvestDate        DateTime?
  expiryDate         DateTime?

  // SEO & Marketing
  metaTitle       String?
  metaDescription String?
  tags            String[]

  isOrganic  Boolean @default(false)
  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@map("products")
}

model CartItem {
  id        String @id @default(cuid())
  userId    String
  productId String
  quantity  Int    @default(1)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("cart_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderType {
  DINE_IN // Customer is at restaurant, food served to table
  TAKEAWAY // Customer picks up from restaurant
  DELIVERY // Food delivered to customer address
  ONLINE_RETAIL // E-commerce retail products
  B2B_WHOLESALE // Partner orders
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BANK_TRANSFER
  DIGITAL_WALLET
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  userId       String
  restaurantId String? // Required for DINE_IN, TAKEAWAY, DELIVERY
  waiterId     String? // Staff member who served the order
  type         OrderType
  status       OrderStatus @default(PENDING)

  // Payment
  paymentStatus PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?

  // Amounts
  subtotal    Float
  tax         Float @default(0)
  shippingFee Float @default(0)
  discount    Float @default(0)
  total       Float

  // Dine-in specific
  tableNumber String? // For DINE_IN orders

  // Delivery/Shipping
  deliveryAddress String? // For DELIVERY orders
  shippingAddress String? // For ONLINE_RETAIL orders
  trackingNumber  String?

  // Pickup details
  pickupTime DateTime? // Scheduled pickup time for TAKEAWAY

  // Customer details (for restaurant orders)
  customerName String? // Customer name for the order
  phoneNumber  String? // Customer phone for order updates

  // Metadata
  notes         String?
  customerNotes String?

  user        User              @relation(fields: [userId], references: [id])
  restaurant  Restaurant?       @relation(fields: [restaurantId], references: [id])
  waiter      Staff?            @relation("WaiterAssignments", fields: [waiterId], references: [id])
  items       OrderItem[]
  preparation OrderPreparation?
  delivery    Delivery?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([userId])
  @@index([restaurantId])
  @@index([status, createdAt])
  @@index([type, createdAt])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String? // For retail orders
  menuItemId String? // For restaurant orders

  quantity Int
  price    Float // Price at time of order

  // Customizations (e.g., "no salt", "extra chocolate")
  // JSON: { "removed": ["salt"], "added": ["chocolate"], "notes": "less spicy" }
  customizations Json?

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id])
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_items")
}

model Review {
  id         String  @id @default(cuid())
  userId     String
  productId  String
  rating     Int // 1-5
  title      String?
  comment    String?
  isVerified Boolean @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("reviews")
}

// ========================================
// PROCESSING
// ========================================

enum ProcessingType {
  SARDINE
  MILK
  MEAT
  VEGETABLE
  FRUIT
  GRAIN
}

model ProcessingFacility {
  id       String         @id @default(cuid())
  name     String
  type     ProcessingType
  location String
  capacity Float // tons per day
  status   String // OPERATIONAL, MAINTENANCE, CLOSED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("processing_facilities")
}

// ========================================
// FARMING
// ========================================

enum FarmType {
  AQUACULTURE // Fish farming
  POULTRY
  LIVESTOCK
  CROPS
}

model Farm {
  id       String   @id @default(cuid())
  name     String
  type     FarmType
  location String
  size     Float // in acres
  status   String // ACTIVE, INACTIVE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("farms")
}

// ========================================
// INVENTORY MANAGEMENT
// ========================================

enum InventoryUnit {
  KG // Kilograms
  G // Grams
  L // Liters
  ML // Milliliters
  PCS // Pieces
  DOZEN
  LBS // Pounds
  OZ // Ounces
  CUPS
  TBSP // Tablespoons
  TSP // Teaspoons
}

enum InventoryCategory {
  FLOUR_GRAIN // Flour, wheat, rice, etc.
  SUGAR_SWEETENER // Sugar, honey, syrup
  DAIRY // Milk, butter, cheese, cream
  EGGS
  OILS_FATS // Cooking oil, butter, lard
  SPICES_HERBS
  VEGETABLES
  FRUITS
  MEAT
  SEAFOOD
  POULTRY
  CHOCOLATE_COCOA
  NUTS_SEEDS
  BAKING_SUPPLIES // Baking powder, yeast, vanilla
  CONDIMENTS
  BEVERAGES
  CANNED_GOODS
  FROZEN
  OTHER
}

model InventoryItem {
  id           String            @id @default(cuid())
  restaurantId String? // Location-specific inventory (nullable for migration)
  name         String
  category     String // Flexible category - can be custom or from predefined list
  unit         InventoryUnit

  // THREE-STATE STOCK TRACKING
  rawStock       Float @default(0) // Available for use/preparation
  wipStock       Float @default(0) // Locked in pre-prepared items
  consumedStock  Float @default(0) // Served to customers (historical)
  totalPurchased Float @default(0) // All-time purchases for tracking

  minimumStock    Float  @default(0) // Alert when raw stock below this
  maximumStock    Float? // Optional max capacity
  reorderPoint    Float? // Automatic reorder trigger
  reorderQuantity Float? // How much to reorder

  // Compound/Pre-prepared ingredient tracking
  isCompound          Boolean @default(false) // Is this a pre-prepared item?
  preparationRecipeId String? @unique // Link to preparation recipe if compound

  // Pricing
  costPerUnit Float? // Cost price
  supplier    String?

  // Storage & expiry
  storageLocation String? // Pantry, Fridge, Freezer
  expiryDate      DateTime?
  batchNumber     String?

  // Metadata
  description String?
  notes       String?
  imageUrl    String? // Image of the ingredient
  size        String? // Size/grade: SMALL, MEDIUM, LARGE, EXTRA_LARGE, JUMBO (universal for all ingredients)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  restaurant         Restaurant?              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  recipeIngredients  RecipeIngredient[]
  stockMovements     StockMovement[]
  preparationRecipe  PreparationRecipe?       @relation("OutputItem")
  usedInPreparations PreparationRecipeInput[]

  @@map("inventory_items")
}

model Recipe {
  id          String @id @default(cuid())
  menuItemId  String @unique
  name        String
  servingSize Int    @default(1) // Number of servings this recipe makes

  instructions String? // Cooking instructions
  prepTime     Int? // in minutes
  cookTime     Int? // in minutes

  // Cost calculation
  totalCost      Float? // Auto-calculated from ingredients
  costPerServing Float?

  // Nutritional Information (per serving)
  calories Int? // Calories per serving
  protein  String? // Protein in grams
  carbs    String? // Carbohydrates in grams
  fat      String? // Fat in grams
  fiber    String? // Fiber in grams
  sodium   String? // Sodium in mg
  sugar    String? // Sugar in grams

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  menuItem    MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@map("recipes")
}

model RecipeIngredient {
  id              String @id @default(cuid())
  recipeId        String
  inventoryItemId String

  quantity Float // Amount needed
  unit     InventoryUnit

  notes String? // e.g., "chopped", "melted", "optional"

  recipe        Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recipeId, inventoryItemId])
  @@map("recipe_ingredients")
}

enum StockMovementType {
  PURCHASE // Buying new stock (affects RAW)
  PRODUCTION // Raw → WIP (bulk preparation)
  USAGE // WIP → Consumed (order served)
  WASTE // Spoiled/damaged
  ADJUSTMENT // Manual correction
  RETURN // Returned to supplier
  TRANSFER // Moved between locations
}

model StockMovement {
  id              String            @id @default(cuid())
  inventoryItemId String
  type            StockMovementType

  quantity Float
  unit     InventoryUnit

  // Track which state is affected
  affectedState String // "RAW", "WIP", or "CONSUMED"

  // Snapshot of all three states before and after
  previousRaw      Float?
  newRaw           Float?
  previousWip      Float?
  newWip           Float?
  previousConsumed Float?
  newConsumed      Float?

  // Reference
  referenceType String? // e.g., "PreparationBatch", "Order", "Purchase"
  referenceId   String? // Batch ID, Order ID, etc.

  // Details
  reason      String?
  notes       String?
  performedBy String? // User ID

  createdAt DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("stock_movements")
}

// Preparation Recipe: Defines how to make a compound/pre-prepared ingredient
// Example: "Pre-boiled Salted Beans" = Beans (raw) + Salt (raw) + Water
model PreparationRecipe {
  id   String @id @default(cuid())
  name String

  // Output: The compound ingredient this recipe creates
  outputItemId   String        @unique
  outputQuantity Float // How much is produced per batch
  outputUnit     InventoryUnit

  // Preparation details
  prepTime        Int? // in minutes
  instructions    String?
  storageLocation String? // Where to store prepared item
  shelfLifeDays   Int? // How long it lasts

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  outputItem InventoryItem            @relation("OutputItem", fields: [outputItemId], references: [id])
  inputs     PreparationRecipeInput[]
  batches    PreparationBatch[]

  @@map("preparation_recipes")
}

// Inputs for a preparation recipe (raw ingredients)
model PreparationRecipeInput {
  id                  String @id @default(cuid())
  preparationRecipeId String
  inventoryItemId     String

  quantity Float
  unit     InventoryUnit

  notes String? // e.g., "rinsed", "soaked overnight"

  preparationRecipe PreparationRecipe @relation(fields: [preparationRecipeId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem     @relation(fields: [inventoryItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([preparationRecipeId, inventoryItemId])
  @@map("preparation_recipe_inputs")
}

// Individual batch of prepared ingredients
// Tracks exactly what raw ingredients were used and how much is left
model PreparationBatch {
  id                  String @id @default(cuid())
  preparationRecipeId String
  batchNumber         String @unique

  quantityProduced  Float // Total amount made
  quantityRemaining Float // How much is left (WIP)
  quantityConsumed  Float @default(0) // How much was used (moved to CONSUMED)

  // JSON snapshot of exactly what raw ingredients were used
  // Example: { "salt": { "quantity": 50, "unit": "G" }, "beans": { "quantity": 2, "unit": "KG" } }
  ingredientsUsed Json

  productionDate DateTime  @default(now())
  expiryDate     DateTime? // Based on shelfLifeDays

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preparationRecipe PreparationRecipe @relation(fields: [preparationRecipeId], references: [id])

  @@map("preparation_batches")
}

// ========================================
// STAFF MANAGEMENT
// ========================================

enum StaffRole {
  CHEF
  SOUS_CHEF
  LINE_COOK
  WAITER
  HOST
  DELIVERY_DRIVER
  MANAGER
  CASHIER
}

enum StaffStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
  TERMINATED
}

model Staff {
  id           String      @id @default(cuid())
  userId       String      @unique // Link to User table
  restaurantId String // Which branch they work at
  role         StaffRole
  status       StaffStatus @default(ACTIVE)

  // Employment details
  employeeId      String    @unique
  hireDate        DateTime
  terminationDate DateTime?
  hourlyRate      Float?
  salary          Float?

  // Work schedule
  workSchedule Json? // { "monday": ["09:00-17:00"], "tuesday": ["09:00-17:00"] }

  // Performance tracking
  ordersCompleted     Int   @default(0) // For chefs/waiters
  deliveriesCompleted Int   @default(0) // For delivery drivers
  averageRating       Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relations
  ordersAsChef   OrderPreparation[] @relation("ChefAssignments")
  ordersAsWaiter Order[]            @relation("WaiterAssignments")
  deliveries     Delivery[]

  @@map("staff")
}

// ========================================
// EQUIPMENT & MAINTENANCE
// ========================================

enum EquipmentType {
  COOKING_APPLIANCE // Oven, stove, grill
  REFRIGERATION // Fridge, freezer, walk-in
  FOOD_PREP // Blender, mixer, food processor
  DISHWASHING // Dishwasher
  MEASUREMENT // Scale, thermometer
  OTHER
}

enum EquipmentStatus {
  OPERATIONAL
  MAINTENANCE_REQUIRED
  UNDER_MAINTENANCE
  OUT_OF_SERVICE
  RETIRED
}

model Equipment {
  id           String          @id @default(cuid())
  restaurantId String
  name         String
  type         EquipmentType
  status       EquipmentStatus @default(OPERATIONAL)

  // Details
  manufacturer   String?
  model          String?
  serialNumber   String?
  purchaseDate   DateTime?
  purchasePrice  Float?
  warrantyExpiry DateTime?

  // Maintenance
  lastMaintenanceDate   DateTime?
  nextMaintenanceDate   DateTime?
  maintenanceCostBudget Float? // Allocated budget for maintenance

  // Usage tracking
  totalUsageHours Float @default(0)
  usageCount      Int   @default(0) // Number of times used

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant      Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  maintenanceLogs MaintenanceLog[]
  usageLogs       EquipmentUsageLog[]

  @@map("equipment")
}

model MaintenanceLog {
  id          String @id @default(cuid())
  equipmentId String

  maintenanceType String // ROUTINE, REPAIR, EMERGENCY, INSPECTION
  description     String
  cost            Float
  performedBy     String? // Technician name or company
  performedById   String? // Staff ID if internal

  startDate     DateTime
  completedDate DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@map("maintenance_logs")
}

model EquipmentUsageLog {
  id          String  @id @default(cuid())
  equipmentId String
  orderId     String? // Link to order if applicable
  recipeId    String? // Link to recipe

  usedAt          DateTime @default(now())
  durationMinutes Int? // How long it was used

  notes String?

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@map("equipment_usage_logs")
}

// ========================================
// DELIVERY & TRACKING
// ========================================

enum DeliveryStatus {
  ASSIGNED // Assigned to driver
  PICKED_UP // Driver picked up from restaurant
  IN_TRANSIT // On the way to customer
  ARRIVED // Driver arrived at location
  DELIVERED // Successfully delivered
  FAILED // Failed delivery attempt
  CANCELLED
}

model Delivery {
  id       String         @id @default(cuid())
  orderId  String         @unique
  driverId String
  status   DeliveryStatus @default(ASSIGNED)

  // Tracking
  assignedAt  DateTime  @default(now())
  pickedUpAt  DateTime?
  inTransitAt DateTime?
  arrivedAt   DateTime?
  deliveredAt DateTime?

  // Location tracking (store last known coordinates)
  currentLatitude    Float?
  currentLongitude   Float?
  lastLocationUpdate DateTime?

  // Delivery details
  estimatedDeliveryTime DateTime?
  actualDeliveryTime    DateTime?
  deliveryNotes         String?

  // Payment tracking
  isPaid          Boolean   @default(false)
  paidAt          DateTime?
  paymentMethod   String? // CASH, CARD, ONLINE
  amountCollected Float?

  // Failed delivery tracking
  failureReason String?
  failureNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver Staff @relation(fields: [driverId], references: [id])

  locationHistory DeliveryLocationHistory[]

  @@map("deliveries")
}

model DeliveryLocationHistory {
  id         String @id @default(cuid())
  deliveryId String

  latitude  Float
  longitude Float
  timestamp DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@map("delivery_location_history")
}

// ========================================
// ORDER PREPARATION & KITCHEN WORKFLOW
// ========================================

enum PreparationStatus {
  PENDING // Order received, not started
  PREPARING // Chef is cooking
  READY // Food is ready
  SERVED // Served to customer (dine-in) or picked up
}

model OrderPreparation {
  id      String            @id @default(cuid())
  orderId String            @unique
  chefId  String?
  status  PreparationStatus @default(PENDING)

  // Timeline
  startedAt DateTime?
  readyAt   DateTime?
  servedAt  DateTime?

  // Photo updates during preparation
  photos String[] // Array of image URLs

  // Notes
  chefNotes    String?
  kitchenNotes String?

  // Estimated time
  estimatedReadyTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  chef  Staff? @relation("ChefAssignments", fields: [chefId], references: [id])

  @@map("order_preparations")
}

// ========================================
// ANALYTICS & REPORTING
// ========================================

model ActivityLog {
  id        String  @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  String? // JSON
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@map("activity_logs")
}
