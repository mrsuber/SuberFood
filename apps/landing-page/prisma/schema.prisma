// SuberFood Monolithic Database Schema
// Comprehensive schema covering IAM, Distribution, Restaurants, Processing, Farming

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// IDENTITY & ACCESS MANAGEMENT (IAM)
// ========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN

  // Distribution Roles
  DISTRIBUTION_MANAGER
  RESTAURANT_MANAGER
  RESTAURANT_STAFF
  RETAIL_MANAGER
  PARTNER_MANAGER

  // Processing Roles
  PROCESSING_MANAGER
  QUALITY_CONTROL

  // Farming Roles
  FARM_MANAGER
  FARM_WORKER

  // Customer Roles
  CUSTOMER
  B2B_PARTNER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String? // Made optional for OAuth users
  firstName     String? // Made optional for OAuth
  lastName      String? // Made optional for OAuth
  name          String? // Full name for OAuth
  phone         String?
  role          UserRole   @default(CUSTOMER)
  status        UserStatus @default(ACTIVE) // Changed default to ACTIVE for easier onboarding
  emailVerified DateTime?
  image         String?

  // Phase 1: Customer preferences
  favoriteMenuItems   String[] // Menu item IDs
  dietaryRestrictions String[] // vegetarian, vegan, keto, etc.
  allergies           String[] // gluten, dairy, nuts, shellfish, etc.
  birthdate           DateTime?
  communicationPrefs  Json? // Email, SMS preferences

  // Phase 2: Enhanced tracking
  lastLoginAt         DateTime?
  loginCount          Int       @default(0)
  preferredRestaurant String? // Restaurant ID
  lifetimeValue       Float     @default(0) // Total spending
  pointsBalance       Int       @default(0) // Loyalty points

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions     Session[]
  accounts     Account[]
  orders       Order[]
  reservations Reservation[]
  addresses    Address[]
  cart         CartItem[]
  reviews      Review[]
  orderHistory UserOrderHistory[]

  @@map("users")
}

// Account model for OAuth providers
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

// Verification tokens for email verification
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// User order history for personalization
model UserOrderHistory {
  id         String   @id @default(cuid())
  userId     String
  menuItemId String? // If restaurant order
  productId  String? // If retail order
  orderId    String
  quantity   Int      @default(1)
  orderedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([menuItemId])
  @@map("user_order_history")
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  type       String // BILLING, SHIPPING, BOTH
  street     String
  city       String
  state      String
  postalCode String
  country    String  @default("USA")
  isDefault  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("addresses")
}

// ========================================
// DISTRIBUTION - RESTAURANTS
// ========================================

enum RestaurantType {
  CLASSICAL_FINE_DINING
  CAFETERIA
  QUICK_SERVICE
}

enum RestaurantStatus {
  OPEN
  CLOSED
  TEMPORARILY_CLOSED
}

model Restaurant {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  type        RestaurantType
  description String?
  address     String
  city        String
  state       String
  postalCode  String
  phone       String
  email       String
  status      RestaurantStatus @default(CLOSED)

  // Operating Hours
  openingTime   String? // e.g., "11:00"
  closingTime   String? // e.g., "22:00"
  operatingDays String? // JSON array of days

  capacity Int   @default(0)
  rating   Float @default(0)

  // Phase 1: Location details
  latitude              Float?
  longitude             Float?
  images                String[] // Array of image URLs
  amenities             String[] // parking, wifi, outdoor seating, etc.
  parkingInfo           String?
  accessibilityFeatures String[] // wheelchair, braille menu, etc.
  privateRooms          Boolean  @default(false)
  outdoorSeating        Boolean  @default(false)
  currentWaitTime       Int? // in minutes

  // Phase 1: About/Story
  story              String? // Restaurant history
  chefBios           Json? // Array of chef profiles
  awards             String[] // Awards and recognition
  sustainabilityInfo String? // Sustainability practices
  pressMedia         Json? // Press coverage links

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  menuCategories MenuCategory[]
  reservations   Reservation[]
  tables         Table[]
  orders         Order[]

  @@map("restaurants")
}

model Table {
  id           String  @id @default(cuid())
  restaurantId String
  tableNumber  String
  capacity     Int
  isAvailable  Boolean @default(true)

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, tableNumber])
  @@map("tables")
}

model MenuCategory {
  id           String  @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("menu_categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  description String?
  price       Float
  salePrice   Float? // For promotional pricing
  image       String?
  images      String[] // Multiple images for gallery
  isAvailable Boolean  @default(true)

  // Phase 1: Dietary information
  isVegetarian Boolean @default(false)
  isVegan      Boolean @default(false)
  isGlutenFree Boolean @default(false)
  isKeto       Boolean @default(false)
  isHalal      Boolean @default(false)
  isKosher     Boolean @default(false)

  // Phase 1: Enhanced details
  calories        Int?
  preparationTime Int? // in minutes
  spiceLevel      Int? // 0-5 scale
  allergens       String[] // gluten, dairy, nuts, shellfish, etc.
  ingredients     String? // Comma-separated or JSON

  // Phase 1: Marketing
  winePairing       String? // Suggested wine/drink pairing
  isChefRecommended Boolean @default(false)
  isSeasonal        Boolean @default(false)
  isPopular         Boolean @default(false)

  // Phase 1: Customer ratings
  averageRating Decimal? @default(0)
  reviewCount   Int      @default(0)

  // Phase 1: Customization options
  customizationOptions Json? // JSON object for modifiers

  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  recipe     Recipe? // One-to-one relationship with Recipe

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("menu_items")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Reservation {
  id           String  @id @default(cuid())
  restaurantId String
  userId       String
  tableId      String?

  reservationDate DateTime
  reservationTime String // e.g., "19:00"
  partySize       Int
  status          ReservationStatus @default(PENDING)

  specialRequests String?
  notes           String?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  table      Table?     @relation(fields: [tableId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reservations")
}

// ========================================
// DISTRIBUTION - E-COMMERCE / RETAIL
// ========================================

enum ProductCategory {
  FRESH_PRODUCE
  DAIRY
  MEAT
  SEAFOOD
  POULTRY
  PROCESSED_FOODS
  BEVERAGES
  BAKERY
  FROZEN
  PANTRY
}

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
  COMING_SOON
}

model Product {
  id          String          @id @default(cuid())
  sku         String          @unique
  name        String
  slug        String          @unique
  description String?
  category    ProductCategory
  status      ProductStatus   @default(ACTIVE)

  price     Float
  salePrice Float?
  cost      Float? // For margin calculation

  // Inventory
  stockQuantity     Int @default(0)
  lowStockThreshold Int @default(10)

  // Product Details
  unit       String // kg, lbs, piece, etc.
  weight     Float?
  dimensions String? // JSON: {length, width, height}

  // Images
  images    String[] // Array of image URLs
  thumbnail String?

  // Traceability
  farmSource         String?
  processingLocation String?
  harvestDate        DateTime?
  expiryDate         DateTime?

  // SEO & Marketing
  metaTitle       String?
  metaDescription String?
  tags            String[]

  isOrganic  Boolean @default(false)
  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@map("products")
}

model CartItem {
  id        String @id @default(cuid())
  userId    String
  productId String
  quantity  Int    @default(1)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("cart_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderType {
  DINE_IN // Customer is at restaurant, food served to table
  TAKEAWAY // Customer picks up from restaurant
  DELIVERY // Food delivered to customer address
  ONLINE_RETAIL // E-commerce retail products
  B2B_WHOLESALE // Partner orders
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BANK_TRANSFER
  DIGITAL_WALLET
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  userId       String
  restaurantId String? // Required for DINE_IN, TAKEAWAY, DELIVERY
  type         OrderType
  status       OrderStatus @default(PENDING)

  // Payment
  paymentStatus PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?

  // Amounts
  subtotal    Float
  tax         Float @default(0)
  shippingFee Float @default(0)
  discount    Float @default(0)
  total       Float

  // Dine-in specific
  tableNumber String? // For DINE_IN orders

  // Delivery/Shipping
  deliveryAddress String? // For DELIVERY orders
  shippingAddress String? // For ONLINE_RETAIL orders
  trackingNumber  String?

  // Pickup details
  pickupTime DateTime? // Scheduled pickup time for TAKEAWAY

  // Customer details (for restaurant orders)
  customerName String? // Customer name for the order
  phoneNumber  String? // Customer phone for order updates

  // Metadata
  notes         String?
  customerNotes String?

  user       User        @relation(fields: [userId], references: [id])
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])
  items      OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String? // For retail orders
  menuItemId String? // For restaurant orders

  quantity Int
  price    Float // Price at time of order

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id])
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_items")
}

model Review {
  id         String  @id @default(cuid())
  userId     String
  productId  String
  rating     Int // 1-5
  title      String?
  comment    String?
  isVerified Boolean @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("reviews")
}

// ========================================
// PROCESSING
// ========================================

enum ProcessingType {
  SARDINE
  MILK
  MEAT
  VEGETABLE
  FRUIT
  GRAIN
}

model ProcessingFacility {
  id       String         @id @default(cuid())
  name     String
  type     ProcessingType
  location String
  capacity Float // tons per day
  status   String // OPERATIONAL, MAINTENANCE, CLOSED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("processing_facilities")
}

// ========================================
// FARMING
// ========================================

enum FarmType {
  AQUACULTURE // Fish farming
  POULTRY
  LIVESTOCK
  CROPS
}

model Farm {
  id       String   @id @default(cuid())
  name     String
  type     FarmType
  location String
  size     Float // in acres
  status   String // ACTIVE, INACTIVE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("farms")
}

// ========================================
// INVENTORY MANAGEMENT
// ========================================

enum InventoryUnit {
  KG // Kilograms
  G // Grams
  L // Liters
  ML // Milliliters
  PCS // Pieces
  DOZEN
  LBS // Pounds
  OZ // Ounces
  CUPS
  TBSP // Tablespoons
  TSP // Teaspoons
}

enum InventoryCategory {
  FLOUR_GRAIN // Flour, wheat, rice, etc.
  SUGAR_SWEETENER // Sugar, honey, syrup
  DAIRY // Milk, butter, cheese, cream
  EGGS
  OILS_FATS // Cooking oil, butter, lard
  SPICES_HERBS
  VEGETABLES
  FRUITS
  MEAT
  SEAFOOD
  POULTRY
  CHOCOLATE_COCOA
  NUTS_SEEDS
  BAKING_SUPPLIES // Baking powder, yeast, vanilla
  CONDIMENTS
  BEVERAGES
  CANNED_GOODS
  FROZEN
  OTHER
}

model InventoryItem {
  id          String            @id @default(cuid())
  name        String
  category    InventoryCategory
  unit        InventoryUnit

  // Stock levels
  currentStock     Float  @default(0)
  minimumStock     Float  @default(0) // Alert when below this
  maximumStock     Float? // Optional max capacity
  reorderPoint     Float? // Automatic reorder trigger
  reorderQuantity  Float? // How much to reorder

  // Pricing
  costPerUnit Float? // Cost price
  supplier    String?

  // Storage & expiry
  storageLocation String? // Pantry, Fridge, Freezer
  expiryDate      DateTime?
  batchNumber     String?

  // Metadata
  description String?
  notes       String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  recipeIngredients RecipeIngredient[]
  stockMovements    StockMovement[]

  @@map("inventory_items")
}

model Recipe {
  id           String  @id @default(cuid())
  menuItemId   String  @unique
  name         String
  servingSize  Int     @default(1) // Number of servings this recipe makes

  instructions String? // Cooking instructions
  prepTime     Int? // in minutes
  cookTime     Int? // in minutes

  // Cost calculation
  totalCost Float? // Auto-calculated from ingredients
  costPerServing Float?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  menuItem    MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@map("recipes")
}

model RecipeIngredient {
  id              String @id @default(cuid())
  recipeId        String
  inventoryItemId String

  quantity Float // Amount needed
  unit     InventoryUnit

  notes String? // e.g., "chopped", "melted", "optional"

  recipe        Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recipeId, inventoryItemId])
  @@map("recipe_ingredients")
}

enum StockMovementType {
  PURCHASE // Buying new stock
  USAGE // Used for cooking
  WASTE // Spoiled/damaged
  ADJUSTMENT // Manual correction
  RETURN // Returned to supplier
  TRANSFER // Moved between locations
}

model StockMovement {
  id              String            @id @default(cuid())
  inventoryItemId String
  type            StockMovementType

  quantity     Float
  unit         InventoryUnit
  previousStock Float // Stock before movement
  newStock     Float // Stock after movement

  // Reference
  referenceType String? // e.g., "Order", "Recipe", "Purchase"
  referenceId   String? // Order ID, Recipe ID, etc.

  // Details
  reason      String?
  notes       String?
  performedBy String? // User ID

  createdAt DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("stock_movements")
}

// ========================================
// ANALYTICS & REPORTING
// ========================================

model ActivityLog {
  id        String  @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  String? // JSON
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@map("activity_logs")
}
